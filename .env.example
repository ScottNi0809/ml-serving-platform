# ===========================
# ML Serving Platform Config
# ===========================

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (SQLite by default, can switch to PostgreSQL)
DATABASE_URL=sqlite:///./data/registry.db

# Model storage
MODEL_STORE_PATH=./model_store

# API authentication
API_KEY=your-api-key-here

# Redis (for caching, optional in phase 1)
# REDIS_HOST=redis
# REDIS_PORT=6379

# LLM Worker
VLLM_BASE_URL=http://localhost:8100
VLLM_DEFAULT_MODEL=Qwen/Qwen2.5-1.5B-Instruct